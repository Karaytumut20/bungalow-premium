generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Vercel için en iyisi
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bungalow {
  id          String   @id @default(cuid())
  title       String
  location    String
  price       Int
  guests      Int
  description String
  features    String[]
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
